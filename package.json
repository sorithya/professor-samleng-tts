{
  "name": "samleng-tts",
  "version": "1.0.0",
  "private": true,
  "description": "Professor Somleng TTS — Khmer Text-to-Speech Desktop Application",
  "author": "Samleng TTS",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "npm run build && electron .",
    "electron:build": "node electron/build.js",
    "electron:build:win": "node electron/build.js --win",
    "electron:build:mac": "node electron/build.js --mac",
    "electron:build:linux": "node electron/build.js --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.samlengtts.app",
    "productName": "Professor Somleng TTS",
    "afterPack": "electron/after-pack.js",
    "copyright": "Copyright © 2026 Professor Somleng TTS",
    "npmRebuild": false,
    "directories": {
      "output": "dist",
      "buildResources": "electron"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "nextapp/.next/standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/static",
        "to": "nextapp/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public",
        "to": "nextapp/public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.png",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Professor Somleng TTS"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    },
    "mac": {
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "electron/icon.png",
      "category": "public.app-category.utilities",
      "artifactName": "${productName}-${version}-macOS-${arch}.${ext}"
    },
    "dmg": {
      "title": "${productName}",
      "artifactName": "${productName}-${version}-macOS-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/icon.png",
      "category": "Audio",
      "artifactName": "${productName}-${version}-Linux.${ext}"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.0",
    "@wavesurfer/react": "^1.0.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.78.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "wavesurfer.js": "^7.12.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
